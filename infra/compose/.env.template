# Resume Platform — production env. Copy to `.env` and fill in. Never commit `.env`.
#   cp .env.template .env

# === Domain & TLS (Caddy) ===
DOMAIN=resume.example.com
SSL_EMAIL=you@example.com

# === Postgres ===
# Strong password; the API connection string is derived from these.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=resume

# === Clerk auth (https://dashboard.clerk.com) ===
# See docs/AUTH.md for how to obtain these. Use pk_live_/sk_live_ in production.
CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx
CLERK_INSTANCE_ID=your-instance-id

# === App ===
# Comma-separated GitHub usernames allowed into /admin. Empty = any signed-in user.
ALLOWED_ADMIN_GITHUB_USERNAMES=your-github-username
FEATURE_ADMIN_EDITING=true
